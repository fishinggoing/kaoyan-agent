# ============================================
# GradSchool Advisor — 环境变量配置模板
# ============================================
# 使用方法:
#   生产环境 (推荐):
#     mkdir -p ~/.gradschool
#     cp .env.example ~/.gradschool/.env
#     vim ~/.gradschool/.env
#
#   本地开发:
#     cp .env.example .env
#     vim .env
#
#   优先级: ~/.gradschool/.env > 项目根目录/.env > 系统环境变量
#   .env 已被 .gitignore 排除，不会被提交到 Git
# ============================================

# DeepSeek API — 在 https://platform.deepseek.com/api_keys 获取
# 这是调用 AI 服务的密钥，不是本地 API Key
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 数据库 (SQLite 本地文件)
DATABASE_URL=sqlite:///./gradschool.db

# ChromaDB 向量数据库持久化目录
CHROMA_PERSIST_DIR=./chroma_data

# 服务器
HOST=127.0.0.1
PORT=8000
DEBUG=false

# CORS — 允许访问前端来源，逗号分隔
# 开发: http://localhost:5173
# 生产: 你的域名, 如 https://your-domain.com
ALLOW_ORIGINS=http://localhost:5173

# 前端静态文件目录 (生产模式)
STATIC_DIR=../frontend/dist

# API Key — 保护写操作和 AI 端点（不同于上面的 DeepSeek API Key）
# 生成随机字符串：
#   Linux/Mac: openssl rand -hex 32
#   Windows:   powershell -Command "[Convert]::ToHexString((New-Object Security.Cryptography.RNGCryptoServiceProvider).GetBytes(32))"
# 不设置则受保护端点无认证（仅开发模式）
API_KEY=your-local-api-key-here

# Server酱 推送通知 (可选) — https://sct.ftqq.com/
SERVERCHAN_KEY=
